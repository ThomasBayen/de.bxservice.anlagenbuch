       evaluationTime: das erste rendert pro Seite, das zweite erst
       am Ende des Reports (sonst stünde überall „1 von 1"). Siehe
       iDempiere-development/docs/jasperreports-knowhow.md. -->
  <pageFooter>
    <band height="20">
      <line>
        <reportElement x="0" y="0" width="535" height="1" forecolor="#E8B12A" uuid="d1e1c001-0002-0020-0001-000000000001"/>
