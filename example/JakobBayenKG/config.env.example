# JBKG-Beispiel — Customer-Deployment-Config
# Kopiere nach config.env (gitignored) und fülle das Passwort.
#
# example/JakobBayenKG/build.sh und bootstrap_roles.py lesen aus dieser
# Datei. Für das System-2Pack-Install nutzt install.sh die separate
# setup/config.env.

# iDempiere-Server (Bayen-Testinstallation: Ports +1 gegenüber Vanilla,
# eigene Postgres-Instanz im Docker-Container)
IDEMPIERE_URL=https://localhost:8444
IDEMPIERE_VERIFY_TLS=0
IDEMPIERE_HOME=/home/USER/iDempiere-development/testinstallation/server

# Bayen-Mandant
IDEMPIERE_CLIENT_ID=1000000
IDEMPIERE_ROLE_ID=1000072
IDEMPIERE_ORG_ID=1000000
IDEMPIERE_USER='Joe User'
IDEMPIERE_PASSWORD=
IDEMPIERE_LANGUAGE=en_US

# Login-Rolle, in die die Master-Rolle „anlagenbuch" eingehängt wird
LOGIN_ROLE_NAME=Datalotte
LOGIN_ROLE_ID=1000072

# Profil-Name für tools/import-ods.py. Definiere das Profil mit den
# Datalotte-Credentials lokal in tools/profiles.local.yaml (gitignored).
ODS_PROFILE=bayen
