# GardenWorld-Demo — Community-Beispiel-Deployment.
# Kopiere nach config.env (gitignored) und passe ggf. an.
#
# example/GardenWorld/build.sh und bootstrap_roles.py lesen aus dieser
# Datei. Für das System-2Pack-Install nutzt install.sh die separate
# setup/config.env.

# iDempiere-Server (Vanilla-Core-Instanz)
IDEMPIERE_URL=https://localhost:8443
IDEMPIERE_VERIFY_TLS=0

# Postgres (nur falls bootstrap einen psql-Fallback braucht — bei
# GardenAdmin nicht erforderlich)
PGHOST=localhost
PGPORT=5432
PGUSER=adempiere
PGPASSWORD=adempiere
PGDATABASE=idempiere

# GardenWorld-Mandant
IDEMPIERE_CLIENT_ID=11
IDEMPIERE_ROLE_ID=102
IDEMPIERE_ORG_ID=11
IDEMPIERE_USER=GardenAdmin
IDEMPIERE_PASSWORD=GardenAdmin
IDEMPIERE_LANGUAGE=en_US

# Login-Rolle, in die die Master-Rolle „anlagenbuch" eingehängt wird
LOGIN_ROLE_NAME=GardenAdmin
LOGIN_ROLE_ID=102

# Profil-Name für tools/import-ods.py (siehe tools/profiles.yaml)
ODS_PROFILE=gardenadmin
