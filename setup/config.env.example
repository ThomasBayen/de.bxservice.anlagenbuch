# Anlagenbuch — Community Install-Config
# Kopiere diese Datei nach config.env (gitignored) und fülle die Werte aus.
#
# install.sh und setup/fix_menu_tree.py lesen ihre Verbindungsdaten aus
# config.env. Für ein Customer-Deployment liegt ein zweites Profil unter
# example/<Kunde>/config.env (für Master-Rolle, Includes, Testdaten).

# iDempiere-Server (REST-API + Server-Pfad für 2Pack-Drop und JRXML-Copy)
IDEMPIERE_URL=https://localhost:8443
IDEMPIERE_VERIFY_TLS=1
IDEMPIERE_HOME=/opt/idempiere-server

# Postgres-Verbindung der iDempiere-DB
PGHOST=localhost
PGPORT=5432
PGUSER=adempiere
PGPASSWORD=
PGDATABASE=idempiere

# System-Mandant für 2Pack-Import (Standard-Werte für die Default-iDempiere-Installation)
IDEMPIERE_CLIENT_ID=0
IDEMPIERE_ROLE_ID=
IDEMPIERE_ORG_ID=0
IDEMPIERE_USER=System
IDEMPIERE_PASSWORD=
IDEMPIERE_LANGUAGE=en_US
